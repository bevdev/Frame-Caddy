<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBg">

    <!-- PLAYBACK top bar (default) -->
    <LinearLayout
        android:id="@+id/playbackTopBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/colorSurface"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FrameCaddy"
            android:textColor="@color/colorText"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCapture"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="📷"
            android:textSize="20sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="4dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/btnAdjust"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="✏"
            android:textSize="20sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="4dp"
            android:padding="0dp" />

        <Button
            android:id="@+id/btnLoadVideo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="📂"
            android:textSize="20sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:padding="0dp" />

    </LinearLayout>

    <!-- ADJUST top bar (GONE by default, swaps in when editing) -->
    <LinearLayout
        android:id="@+id/adjustTopBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/colorSurface"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btnToolPan"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="✋"
            android:textSize="16sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtnDark"
            android:layout_marginEnd="3dp"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnToolDraw"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="✏"
            android:textSize="16sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="3dp"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnToolLine"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="⟋"
            android:textSize="16sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="3dp"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="↩"
            android:textSize="16sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="3dp"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnClearDraw"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="🗑"
            android:textSize="16sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="8dp"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <View
            android:id="@+id/btnColorRed"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="#F44336"
            android:layout_marginEnd="5dp" />

        <View
            android:id="@+id/btnColorBlue"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="#2196F3"
            android:layout_marginEnd="5dp" />

        <View
            android:id="@+id/btnColorYellow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="#FFEB3B" />

        <!-- Spacer pushes Done to the right -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnDone"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="✓"
            android:textSize="18sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="#4CAF50"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

    </LinearLayout>

    <!-- Video area — takes remaining space -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"
        android:minHeight="180dp">

        <FrameLayout
            android:id="@+id/videoContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true">

            <androidx.media3.ui.PlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="false"
                app:resize_mode="fit" />

            <com.framecaddy.app.DrawingOverlayView
                android:id="@+id/drawingView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvNoVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Tap 📂 to load a video"
            android:textColor="#80FFFFFF"
            android:textSize="14sp" />

    </FrameLayout>

    <!-- Info bar: trim range + current position -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="@color/colorSurface">

        <TextView
            android:id="@+id/tvTrimInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start: 0ms  |  End: --"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvPosition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0ms"
            android:textColor="@color/colorBtn"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Seek bar -->
    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="2dp"
        android:progressTint="@color/colorBtn"
        android:thumbTint="@color/colorBtn" />

    <!-- Step row — always visible -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <Button
            android:id="@+id/btnBack500"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.9"
            android:text="-500"
            android:textSize="10sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnBack250"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.9"
            android:text="-250"
            android:textSize="10sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnBack100"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.9"
            android:text="-100"
            android:textSize="10sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:text="▶"
            android:textSize="18sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnFwd100"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.9"
            android:text="+100"
            android:textSize="10sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnFwd250"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.9"
            android:text="+250"
            android:textSize="10sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnFwd500"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.9"
            android:text="+500"
            android:textSize="10sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn" />

    </LinearLayout>

    <!-- Speed + Trim + Save row — always visible -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <Button
            android:id="@+id/btnSpeed025"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text=".25×"
            android:textSize="11sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnSpeed05"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text=".5×"
            android:textSize="11sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnSpeed1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="1×"
            android:textSize="11sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtnDark"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnSetStart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:text="▸ Start"
            android:textSize="11sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorTrim"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnSetEnd"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:text="End ◂"
            android:textSize="11sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorTrim"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnSaveFrame"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="💾"
            android:textSize="18sp"
            android:textColor="@color/colorBtnText"
            android:backgroundTint="@color/colorBtn" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="8dp" />

</LinearLayout>
